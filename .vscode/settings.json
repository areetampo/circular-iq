{
  "search.exclude": {
    "**/.husky/**": true,
    "**/.scratch/**": true,
    "**/backend/database/migrations/**": true,
    "**/backend/datasets/{archives,for_search,manual_entries,out,processed,raw,test_inputs}/**": true,
    "**/*.{csv,jsonl,pdf,sql}": true
  },

  "files.exclude": {
    "**/*.{pdf,csv}": false,
    "**/backend/datasets/archives/scrape_backup/**": false,
    "**/backend/datasets/archives/**.{json,jsonl}": false,
    "**/backend/datasets/archives/{chunks.json,embedded_chunks.jsonl,stored_documents.jsonl}": true,
    "**/backend/datasets/for_search/**": false,
    "**/backend/datasets/manual_entries/**": false,
    "**/backend/datasets/out/**.{json,jsonl}": false,
    "**/backend/datasets/out/{chunks.json,embedded_chunks.jsonl,stored_documents.jsonl}": true,
    "**/backend/datasets/processed/**": false,
    "**/backend/datasets/raw/**": false,
    "**/backend/datasets/test_inputs/**": false
  },

  "files.watcherExclude": {
    "**/.husky/**": true,
    "**/.scratch/**": true,
    "**/backend/datasets/**": true,
    "**/backend/tests/**": true,
    "**/frontend/dist/**": true
  },

  "eslint.workingDirectories": [{ "mode": "auto" }],

  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },

  "git.autorefresh": true,
  "git.confirmSync": false,
  "git.autofetch": false
}
