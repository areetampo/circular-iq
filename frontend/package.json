{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Frontend for RAG-powered evaluator for circular economy business evaluations",
  "author": "Areeb Ahmed Zahoori <zahooriareeb47@gmail.com>",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=24.x"
  },
  "scripts": {
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL && process.env.NODE_ENV !== 'production') { try { require('husky').install() } catch (e) { console.log('Husky not available, skipping'); } }\"",
    "x": "node -e \"if (process.env.NODE_ENV !== 'production' && !process.env.CI && !process.env.VERCEL) { try { require('husky').install() } catch (e) { console.log('Skipping husky'); } }\"",
    "dev": "vite --mode frontend",
    "build": "vite build --mode production",
    "lint": "eslint .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "preview": "vite preview",
    "clean": "npx rimraf node_modules"
  },
  "dependencies": {
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.90.16",
    "clsx": "^2.1.1",
    "framer-motion": "^12.31.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "ldrs": "^1.1.9",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.3",
    "react": "^19.2.0",
    "react-aria": "^3.47.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "history": "^5.3.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
