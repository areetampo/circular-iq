{
  "name": "circular-economy-evaluator",
  "private": true,
  "version": "1.0.0",
  "description": "RAG-powered evaluator for circular economy business evaluations",
  "type": "module",
  "author": "Areeb Ahmed Zahoori <areebrawl@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "clean": "npx rimraf node_modules package-lock.json backend/node_modules backend/package-lock.json frontend/node_modules frontend/package-lock.json",
    "rei": "npm run clean && npm install",
    "dev": "concurrently -n BACKEND,FRONTEND -c \"yellow,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": "npm run dev -w backend",
    "frontend": "npm run dev -w frontend",
    "lint": "eslint .",
    "lint:errors": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "lint:frontend": "eslint frontend",
    "format": "prettier --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "fix-all": "npm run lint:fix && npm run format && npm run knip:fix",
    "test": "npm test --workspaces --if-present",
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL) { try { require('husky').install() } catch (e) { console.log('Husky not available, skipping'); } }\"",
    "build": "npm run build --workspaces --if-present"
  },
  "keywords": [
    "AI",
    "LLM",
    "RAG",
    "Vector Search",
    "Vector Database",
    "Embeddings",
    "Machine Learning",
    "Data Science",
    "Circular Economy",
    "Sustainability",
    "Green Tech",
    "Climate Tech",
    "Business Intelligence",
    "Supply Chain Optimization",
    "Sustainable Development"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/areetampo/circular-economy.git"
  },
  "bugs": {
    "url": "https://github.com/areetampo/circular-economy/issues"
  },
  "homepage": "https://github.com/areetampo/circular-economy#readme",
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/config-helpers": "^0.6.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --quiet",
      "prettier --write"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
