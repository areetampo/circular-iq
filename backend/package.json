{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "description": "RAG-powered evaluator for circular economy business evaluations",
  "author": "Areeb Ahmed Zahoori <areebrawl@gmail.com>",
  "license": "MIT",
  "main": "server/index.js",
  "type": "module",
  "imports": {
    "#config/*": "./config/*",
    "#constants/*": "./constants/*",
    "#controllers/*": "./controllers/*",
    "#database/*": "./database/*",
    "#datasets/*": "./datasets/*",
    "#middleware/*": "./middleware/*",
    "#pipeline/*": "./pipeline/*",
    "#routes/*": "./routes/*",
    "#server/*": "./server/*",
    "#services/*": "./services/*",
    "#tests/*": "./tests/*",
    "#utils/*": "./utils/*"
  },
  "scripts": {
    "clean": "npx rimraf node_modules package-lock.json",
    "rei": "npm run clean && npm install",
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "datasets-scripts": "node pipeline/rag/run_datasets_scripts.js",
    "merge": "node pipeline/rag/merge_datasets.js",
    "chunk": "node pipeline/rag/generate_chunks.js",
    "embed": "node pipeline/rag/generate_embeddings.js",
    "store": "node pipeline/rag/store_embeddings.js",
    "populate": "npm run merge && npm run chunk && npm run embed && npm run store",
    "test": "node tests/run-tests.js",
    "prepare": "node -e \"try{require('husky').install()}catch(e){}\"",
    "build": "echo 'No build step required for backend'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "boxen": "^8.0.1",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "csv-parse": "^5.5.2",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^6.0.1",
    "openai": "^4.28.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "axios": "^1.13.5",
    "csv-stringify": "^6.6.0",
    "eslint": "^9.39.2",
    "exceljs": "^4.4.0",
    "globals": "^17.1.0",
    "google-translate-api-x": "^10.7.2",
    "got": "^14.6.6",
    "pdfjs-dist": "^5.4.624",
    "pg-copy-streams": "^7.0.0",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.37.5",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "supertest": "^6.3.4",
    "tabula-js": "^1.0.1",
    "tiktoken": "^1.0.22"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
