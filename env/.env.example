# =============================================================================
# MONOREPO — .env.example
# =============================================================================
#
# Backend  →  apps/backend/.env
# Frontend →  apps/frontend/.env
#
# Variables marked [Render] or [Vercel] are managed in the platform dashboard.
# Never commit real secrets.
# =============================================================================


# =============================================================================
# BACKEND — apps/backend/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

NODE_ENV=
PORT=

APP_URL=
API_URL=

LOG_LEVEL=
STRICT_ENV=

# -----------------------------------------------------------------------------
# Test Credentials
# (required in development/test; optional in production)
# -----------------------------------------------------------------------------

TEST_USER_NAME=
TEST_USER_NAME_EXT=
TEST_USER_PASSWORD=

# -----------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# -----------------------------------------------------------------------------

ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_HOST=
SUPABASE_PORT=
SUPABASE_DATABASE=
SUPABASE_USER=
SUPABASE_PASSWORD=

SUPABASE_CONNECTION_LIMIT=
SUPABASE_IDLE_TIMEOUT_MS=

# Format: postgresql://[SUPABASE_USER]:[SUPABASE_PASSWORD]@[SUPABASE_HOST]:[SUPABASE_PORT]/[SUPABASE_DATABASE]
SUPABASE_CONNECTION_STRING=

# -----------------------------------------------------------------------------
# Aiven PostgreSQL
# -----------------------------------------------------------------------------

AIVEN_HOST=
AIVEN_PORT=
AIVEN_DATABASE=
AIVEN_USER=
AIVEN_PASSWORD=

# Options: disable | require | verify-ca | verify-full
AIVEN_SSL_MODE=

AIVEN_CONNECTION_LIMIT=
AIVEN_IDLE_TIMEOUT_MS=

# Format: postgres://[AIVEN_USER]:[AIVEN_PASSWORD]@[AIVEN_HOST]:[AIVEN_PORT]/[AIVEN_DATABASE]?sslmode=[AIVEN_SSL_MODE]
AIVEN_CONNECTION_STRING=

# Paste full CA certificate content when AIVEN_SSL_MODE is verify-ca or verify-full
AIVEN_CA_CERT="-----BEGIN CERTIFICATE-----
YOUR_CA_CERTIFICATE_CONTENT_HERE
-----END CERTIFICATE-----"

# -----------------------------------------------------------------------------
# Scoring / Documents
# -----------------------------------------------------------------------------

USE_SUPABASE_DOCUMENTS_TABLE=

ANON_SCORING_LIMIT=
ANON_SCORING_USAGE_RETENTION_DAYS=

# -----------------------------------------------------------------------------
# Uptime Checks
# -----------------------------------------------------------------------------

# Polling interval in ms — minimum 5000
UPTIME_CHECKS_POLL_INTERVAL_MS=

# Max stored history entries per endpoint — range 1–21600 (21600 ≈ 30 days at 2-min cadence)
UPTIME_CHECKS_MAX_HISTORY_PER_ENDPOINT=

# Max lookback window for queries in days — range 1–28
UPTIME_CHECKS_QUERY_WINDOW_DAYS_LIMIT=

# How long to retain uptime records in days — minimum 1
UPTIME_CHECKS_RETENTION_DAYS=

# Run cleanup job on server start — true | false
UPTIME_CHECKS_CLEANUP_ON_START=

# Cleanup job interval in ms — range 3600000–86400000 (1h–24h)
UPTIME_CHECKS_CLEANUP_INTERVAL_MS=

# -----------------------------------------------------------------------------
# API Authentication
# -----------------------------------------------------------------------------

API_AUTH_ENABLED=

# Required when API_AUTH_ENABLED=true; leave blank otherwise
# Must match INTERNAL_BACKEND_API_KEY set on Vercel [Render]
API_KEY=

# -----------------------------------------------------------------------------
# CI / Platform Tooling
# -----------------------------------------------------------------------------

# Prevents git-lfs smudge filter from running during build [Render]
GIT_LFS_SKIP_SMUDGE=

# Set to 0 to skip Husky in the build environment [Render]
HUSKY=


# =============================================================================
# FRONTEND — apps/frontend/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

VITE_APP_URL=
VITE_API_URL=

VITE_STRICT_ENV=

# -----------------------------------------------------------------------------
# Test Credentials
# -----------------------------------------------------------------------------

VITE_TEST_USER_NAME=
VITE_TEST_USER_NAME_EXT=
VITE_TEST_USER_PASSWORD=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Uptime Checks — keep values in sync with backend equivalents above
# -----------------------------------------------------------------------------

# UI refetch interval in ms — minimum 5000; align with UPTIME_CHECKS_POLL_INTERVAL_MS
VITE_UPTIME_CHECKS_REFETCH_INTERVAL_MS=

# Align with UPTIME_CHECKS_MAX_HISTORY_PER_ENDPOINT
VITE_UPTIME_CHECKS_MAX_HISTORY_PER_ENDPOINT=

# Align with UPTIME_CHECKS_QUERY_WINDOW_DAYS_LIMIT
VITE_UPTIME_CHECKS_QUERY_WINDOW_DAYS_LIMIT=

# -----------------------------------------------------------------------------
# API Authentication
# -----------------------------------------------------------------------------

# Shared secret forwarded to the backend — must match API_KEY on Render [Vercel]
INTERNAL_BACKEND_API_KEY=

# -----------------------------------------------------------------------------
# CI / Platform Tooling
# -----------------------------------------------------------------------------

# Set to 0 to skip Husky in the build environment [Vercel]
HUSKY=
