################################
# Dependencies
################################
node_modules/
jspm_packages/

################################
# Environment Variables (SECRETS)
################################
# Root env folder (real values ignored)
env/.env.shared
env/.env.frontend
env/.env.backend

# Any accidental local env files
.env
.env.local
.env.*.local
*.local

# Allow template
!env/.env.example

################################
# Datasets
################################
# 1. Enter the datasets directory
backend/datasets/

# 2. Ignore ALL files and subfolders by default
backend/datasets/**/*

# 3. UN-IGNORE (allow) all .gitkeep files at any depth
# This keeps the folder structure (archives, raw, raw/epa_tri, etc.)
!backend/datasets/**/.gitkeep

# 4. UN-IGNORE all files directly inside the datasets root
# (This covers any .js or .md files in the main folder)
!backend/datasets/*

# 5. UN-IGNORE all files in the scripts folder
# (Optional: If you want your JS extraction scripts to be pushed)
!backend/datasets/scripts/*

################################
