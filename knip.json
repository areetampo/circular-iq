{
  "$schema": "./node_modules/knip/schema.json",
  "workspaces": {
    "frontend": {
      "vite": "vite.config.js",
      "project": ["src/**/*.{js,jsx,ts,tsx}!"],
      "entry": ["src/**/*.test.{js,jsx}!", "src/test/**/*.{js,jsx}!"],
      "ignore": ["src/setupTests.js"]
    },
    "backend": {
      "paths": {
        "#config/*": ["config/*"],
        "#constants/*": ["constants/*"],
        "#controllers/*": ["controllers/*"],
        "#database/*": ["database/*"],
        "#datasets/*": ["datasets/*"],
        "#middleware/*": ["middleware/*"],
        "#pipeline/*": ["pipeline/*"],
        "#routes/*": ["routes/*"],
        "#server/*": ["server/*"],
        "#services/*": ["services/*"],
        "#tests/*": ["tests/*"],
        "#utils/*": ["utils/*"]
      },
      "entry": ["pipeline/*.js", "datasets/scripts/*.js", "tests/**/*.test.js!", "tests/**/*.js!"],
      "project": ["**/*.js!"]
    }
  }
}
